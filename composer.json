{
    "name": "marko/skeleton",
    "description": "Marko Framework - Application Skeleton",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": "^8.5",
        "marko/env": "*",
        "marko/framework": "*"
    },
    "require-dev": {
        "marko/dev-server": "*",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "App\\Foo\\": "app/foo/src/",
            "App\\Web\\": "app/web/src/",
            "Marko\\Vite\\": "modules/vite/src/",
            "Marko\\Inertia\\": "modules/inertia/src/",
            "Marko\\InertiaVue\\": "modules/inertia-vue/src/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
