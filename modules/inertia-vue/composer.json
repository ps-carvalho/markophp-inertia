{
  "name": "marko/inertia-vue",
  "type": "marko-module",
  "description": "Vue 3 companion for marko/inertia — scaffolding and SSR server entry point",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "marko/core": "*",
    "marko/inertia": "*",
    "marko/vite": "*"
  },
  "require-dev": {
    "pestphp/pest": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Marko\\InertiaVue\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Marko\\InertiaVue\\Tests\\": "tests/"
    }
  },
  "extra": {
    "marko": {
      "module": true
    }
  }
}
