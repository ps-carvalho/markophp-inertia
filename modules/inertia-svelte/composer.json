{
  "name": "marko/inertia-svelte",
  "type": "marko-module",
  "description": "Svelte companion for marko/inertia — configuration for Svelte client and SSR entries",
  "license": "MIT",
  "require": {
    "php": "^8.5",
    "marko/core": "*",
    "marko/inertia": "*",
    "marko/vite": "*"
  },
  "require-dev": {
    "pestphp/pest": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "Marko\\InertiaSvelte\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Marko\\InertiaSvelte\\Tests\\": "tests/"
    }
  },
  "extra": {
    "marko": {
      "module": true
    }
  }
}
